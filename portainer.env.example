# Configuração mínima para Portainer.
# Use exatamente o endereço aberto no navegador, incluindo a porta.
APP_NAME=Sinaliza Chat Aviso
APP_URL=http://IP_DO_SERVIDOR:5488
APP_PORT=5488
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en

# Use true somente quando APP_URL utilizar HTTPS.
SESSION_SECURE_COOKIE=false

# API opcional para envio de e-mails.
MAIL_API_URL=https://nest.juancjc.com.br/api-nest-central-jc/mail/send
MAIL_API_KEY=
MAIL_API_TOKEN=
MAIL_API_TIMEOUT=15

# O WebSocket Reverb funciona automaticamente pela mesma APP_URL e APP_PORT.
# APP_KEY, REVERB_APP_SECRET e o banco SQLite são gerados automaticamente.

# PostgreSQL externo opcional. Descomente para substituir o SQLite.
# DB_CONNECTION=pgsql
# DB_HOST=postgres.seudominio.com
# DB_PORT=5432
# DB_DATABASE=chat_aviso
# DB_USERNAME=chat_aviso
# DB_PASSWORD=troque-esta-senha
# DB_SSLMODE=prefer
