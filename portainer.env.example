# Endereço público usado nos links gerados pelo Laravel.
APP_URL=https://chat.seudominio.com

# Porta publicada no servidor. Use outra porta caso ela já esteja ocupada.
APP_PORT=5488

# PostgreSQL existente. O host precisa ser acessível pelo container da aplicação.
DB_CONNECTION=pgsql
DB_HOST=postgres.seudominio.com
DB_PORT=5432
DB_DATABASE=chat_aviso
DB_USERNAME=chat_aviso
DB_PASSWORD=troque-esta-senha
DB_SSLMODE=prefer

# Quantidade de workers Laravel gerenciados pelo PM2.
QUEUE_WORKERS=1
QUEUE_NAMES=default
QUEUE_TRIES=3
QUEUE_TIMEOUT=120
QUEUE_MAX_TIME=3600

# Ative quando APP_URL utilizar HTTPS.
SESSION_SECURE_COOKIE=true

# API utilizada para o envio de e-mails.
MAIL_API_URL=https://nest.juancjc.com.br/api-nest-central-jc/mail/send
MAIL_API_KEY=sua-chave
MAIL_API_TOKEN=seu-token
MAIL_API_TIMEOUT=15
